# Copy this file to .env and fill in real values

# API & Mock Configuration
# VITE_USE_MOCK=true  : Use MSW mocks (good for development without real API)
# VITE_USE_MOCK=false : Use real Claude API calls via dev-server proxy
VITE_USE_MOCK=false

# Base URL for backend API (used when proxying non-AI requests)
VITE_API_BASE_URL=http://localhost:3000

# Claude API Key (ONLY used server-side in dev-server, never exposed to browser)
# Get your key from https://console.anthropic.com/
# Keep this secret! Never commit the actual key to git.
VITE_CLAUDE_API_KEY=sk-ant-api-your-key-here

# Debug options
VITE_BFF_LOG_BODY=false
